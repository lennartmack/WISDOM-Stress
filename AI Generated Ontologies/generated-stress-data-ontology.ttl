@prefix : <http://example.org/generated-stress-data#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix schema: <http://schema.org/> .

<http://example.org/generated-stress-data>
    a owl:Ontology ;
    rdfs:label "Generated wearable stress experiment data ontology"@en ;
    rdfs:comment "An OWL 2 ontology for representing wearable- and sensor-based human stress experiment data derived from WFDB-style example records containing accelerometer, temperature, electrodermal activity, oxygen saturation, heart rate, subject demographics, and stress-phase annotations."@en ;
    owl:versionInfo "1.0.0" .

#################################################################
# Classes
#################################################################

:StressDataEntity a owl:Class ;
    rdfs:label "Stress data entity"@en ;
    rdfs:comment "A top-level grouping class for entities introduced by this ontology for stress experiment data representation."@en .

:StressExperiment a owl:Class ;
    rdfs:subClassOf :StressDataEntity ;
    rdfs:label "Stress experiment"@en ;
    rdfs:comment "An experimental study or recording session collection in which human physiological and motion data are captured during stress-related conditions."@en .

:Participant a owl:Class ;
    rdfs:subClassOf schema:Person, :StressDataEntity ;
    rdfs:label "Participant"@en ;
    rdfs:comment "A human subject participating in a wearable stress experiment."@en .

:DemographicProfile a owl:Class ;
    rdfs:subClassOf :StressDataEntity ;
    rdfs:label "Demographic profile"@en ;
    rdfs:comment "A profile containing demographic and anthropometric attributes of a participant, such as age, gender, height, and weight."@en .

:DatasetRecord a owl:Class ;
    rdfs:subClassOf :StressDataEntity ;
    rdfs:label "Dataset record"@en ;
    rdfs:comment "A named machine-readable recording record consisting of one or more sampled signal channels and associated metadata files."@en .

:MultichannelSignalRecord a owl:Class ;
    rdfs:subClassOf :DatasetRecord ;
    rdfs:label "Multichannel signal record"@en ;
    rdfs:comment "A dataset record containing two or more synchronously sampled signal channels."@en .

:AccelerometryTemperatureEdaRecord a owl:Class ;
    rdfs:subClassOf :MultichannelSignalRecord ;
    rdfs:label "Accelerometry temperature EDA record"@en ;
    rdfs:comment "A multichannel record containing three-axis acceleration, temperature, and electrodermal activity channels."@en .

:OxygenSaturationHeartRateRecord a owl:Class ;
    rdfs:subClassOf :MultichannelSignalRecord ;
    rdfs:label "Oxygen saturation heart rate record"@en ;
    rdfs:comment "A multichannel record containing peripheral oxygen saturation and heart rate channels."@en .

:RecordFile a owl:Class ;
    rdfs:subClassOf schema:DigitalDocument, :StressDataEntity ;
    rdfs:label "Record file"@en ;
    rdfs:comment "A digital file that stores part of a physiological or motion dataset record."@en .

:HeaderFile a owl:Class ;
    rdfs:subClassOf :RecordFile ;
    rdfs:label "Header file"@en ;
    rdfs:comment "A file containing record metadata such as channel names, sampling frequency, sample count, gain, baseline, units, and participant metadata."@en .

:BinarySignalFile a owl:Class ;
    rdfs:subClassOf :RecordFile ;
    rdfs:label "Binary signal file"@en ;
    rdfs:comment "A binary data file containing sampled signal values."@en .

:AnnotationFile a owl:Class ;
    rdfs:subClassOf :RecordFile ;
    rdfs:label "Annotation file"@en ;
    rdfs:comment "A file containing annotations for experimental phases or conditions such as relax and stress phases."@en .

:WearableDevice a owl:Class ;
    rdfs:subClassOf ssn:System, :StressDataEntity ;
    rdfs:label "Wearable device"@en ;
    rdfs:comment "A body-worn sensing system used to acquire physiological or motion signals from a participant."@en .

:Sensor a owl:Class ;
    rdfs:subClassOf sosa:Sensor, :StressDataEntity ;
    rdfs:label "Sensor"@en ;
    rdfs:comment "A sensing component that observes a physiological or motion property."@en .

:Accelerometer a owl:Class ; rdfs:subClassOf :Sensor ; rdfs:label "Accelerometer"@en ; rdfs:comment "A sensor used to measure acceleration along one or more axes."@en .
:TemperatureSensorClass a owl:Class ; rdfs:subClassOf :Sensor ; rdfs:label "Temperature sensor"@en ; rdfs:comment "A sensor used to measure body or skin temperature."@en .
:ElectrodermalActivitySensor a owl:Class ; rdfs:subClassOf :Sensor ; rdfs:label "Electrodermal activity sensor"@en ; rdfs:comment "A sensor used to measure electrodermal activity as a physiological signal related to skin conductance."@en .
:PulseOximeter a owl:Class ; rdfs:subClassOf :Sensor ; rdfs:label "Pulse oximeter"@en ; rdfs:comment "A sensor used to measure peripheral oxygen saturation."@en .
:HeartRateSensorClass a owl:Class ; rdfs:subClassOf :Sensor ; rdfs:label "Heart rate sensor"@en ; rdfs:comment "A sensor used to measure heart rate."@en .

:SignalChannel a owl:Class ;
    rdfs:subClassOf :StressDataEntity ;
    rdfs:label "Signal channel"@en ;
    rdfs:comment "A single named sampled channel in a dataset record."@en .

:AccelerationChannel a owl:Class ; rdfs:subClassOf :SignalChannel ; rdfs:label "Acceleration channel"@en ; rdfs:comment "A signal channel representing acceleration along a specified axis."@en .
:XAxisAccelerationChannel a owl:Class ; rdfs:subClassOf :AccelerationChannel ; rdfs:label "X-axis acceleration channel"@en ; rdfs:comment "A signal channel representing acceleration on the x axis."@en .
:YAxisAccelerationChannel a owl:Class ; rdfs:subClassOf :AccelerationChannel ; rdfs:label "Y-axis acceleration channel"@en ; rdfs:comment "A signal channel representing acceleration on the y axis."@en .
:ZAxisAccelerationChannel a owl:Class ; rdfs:subClassOf :AccelerationChannel ; rdfs:label "Z-axis acceleration channel"@en ; rdfs:comment "A signal channel representing acceleration on the z axis."@en .
:TemperatureChannel a owl:Class ; rdfs:subClassOf :SignalChannel ; rdfs:label "Temperature channel"@en ; rdfs:comment "A signal channel representing temperature values."@en .
:ElectrodermalActivityChannel a owl:Class ; rdfs:subClassOf :SignalChannel ; rdfs:label "Electrodermal activity channel"@en ; rdfs:comment "A signal channel representing electrodermal activity values."@en .
:OxygenSaturationChannel a owl:Class ; rdfs:subClassOf :SignalChannel ; rdfs:label "Oxygen saturation channel"@en ; rdfs:comment "A signal channel representing peripheral oxygen saturation values."@en .
:HeartRateChannel a owl:Class ; rdfs:subClassOf :SignalChannel ; rdfs:label "Heart rate channel"@en ; rdfs:comment "A signal channel representing heart rate values."@en .

:ObservableProperty a owl:Class ;
    rdfs:subClassOf sosa:ObservableProperty, :StressDataEntity ;
    rdfs:label "Observable property"@en ;
    rdfs:comment "A property of a participant observed by a wearable or physiological sensor."@en .

:Acceleration a owl:Class ; rdfs:subClassOf :ObservableProperty ; rdfs:label "Acceleration"@en ; rdfs:comment "Motion acceleration observed along an axis."@en .
:XAxisAcceleration a owl:Class ; rdfs:subClassOf :Acceleration ; rdfs:label "X-axis acceleration"@en ; rdfs:comment "Acceleration observed on the x axis."@en .
:YAxisAcceleration a owl:Class ; rdfs:subClassOf :Acceleration ; rdfs:label "Y-axis acceleration"@en ; rdfs:comment "Acceleration observed on the y axis."@en .
:ZAxisAcceleration a owl:Class ; rdfs:subClassOf :Acceleration ; rdfs:label "Z-axis acceleration"@en ; rdfs:comment "Acceleration observed on the z axis."@en .
:BodyTemperature a owl:Class ; rdfs:subClassOf :ObservableProperty ; rdfs:label "Body temperature"@en ; rdfs:comment "Temperature observed from a participant during a recording."@en .
:ElectrodermalActivity a owl:Class ; rdfs:subClassOf :ObservableProperty ; rdfs:label "Electrodermal activity"@en ; rdfs:comment "Electrodermal activity observed from a participant."@en .
:PeripheralOxygenSaturation a owl:Class ; rdfs:subClassOf :ObservableProperty ; rdfs:label "Peripheral oxygen saturation"@en ; rdfs:comment "Peripheral blood oxygen saturation observed from a participant."@en .
:HeartRate a owl:Class ; rdfs:subClassOf :ObservableProperty ; rdfs:label "Heart rate"@en ; rdfs:comment "Heart rate observed from a participant."@en .

:ExperimentalCondition a owl:Class ; rdfs:subClassOf :StressDataEntity ; rdfs:label "Experimental condition"@en ; rdfs:comment "A labeled experimental state or condition associated with a phase of a recording."@en .
:RelaxCondition a owl:Class ; rdfs:subClassOf :ExperimentalCondition ; rdfs:label "Relax condition"@en ; rdfs:comment "An experimental condition labeled as relaxation or non-stress in the annotation data."@en .
:StressCondition a owl:Class ; rdfs:subClassOf :ExperimentalCondition ; rdfs:label "Stress condition"@en ; rdfs:comment "An experimental condition labeled as stress in the annotation data."@en .
:PhysicalStressCondition a owl:Class ; rdfs:subClassOf :StressCondition ; rdfs:label "Physical stress condition"@en ; rdfs:comment "A stress condition labeled as physical stress."@en .
:EmotionalStressCondition a owl:Class ; rdfs:subClassOf :StressCondition ; rdfs:label "Emotional stress condition"@en ; rdfs:comment "A stress condition labeled as emotional stress."@en .
:CognitiveStressCondition a owl:Class ; rdfs:subClassOf :StressCondition ; rdfs:label "Cognitive stress condition"@en ; rdfs:comment "A stress condition labeled as cognitive stress."@en .

:ExperimentalPhase a owl:Class ; rdfs:subClassOf :StressDataEntity ; rdfs:label "Experimental phase"@en ; rdfs:comment "A labeled segment or phase of an experimental record associated with one experimental condition."@en .
:SampleObservation a owl:Class ; rdfs:subClassOf sosa:Observation, :StressDataEntity ; rdfs:label "Sample observation"@en ; rdfs:comment "An observation corresponding to a sampled value from a signal channel."@en .
:SignalObservationCollection a owl:Class ; rdfs:subClassOf sosa:ObservationCollection, :StressDataEntity ; rdfs:label "Signal observation collection"@en ; rdfs:comment "A collection of sampled observations belonging to a dataset record or channel."@en .
:Unit a owl:Class ; rdfs:subClassOf :StressDataEntity ; rdfs:label "Unit"@en ; rdfs:comment "A unit symbol used to represent physical values in a signal channel."@en .

#################################################################
# Object properties
#################################################################

:hasParticipant a owl:ObjectProperty ; rdfs:domain :StressExperiment ; rdfs:range :Participant ; rdfs:label "has participant"@en ; rdfs:comment "Relates a stress experiment to a participating subject."@en .
:participatesIn a owl:ObjectProperty ; owl:inverseOf :hasParticipant ; rdfs:domain :Participant ; rdfs:range :StressExperiment ; rdfs:label "participates in"@en ; rdfs:comment "Relates a participant to the stress experiment in which they participate."@en .
:hasDemographicProfile a owl:ObjectProperty ; rdfs:domain :Participant ; rdfs:range :DemographicProfile ; rdfs:label "has demographic profile"@en ; rdfs:comment "Relates a participant to demographic and anthropometric data."@en .
:profileOf a owl:ObjectProperty ; owl:inverseOf :hasDemographicProfile ; rdfs:domain :DemographicProfile ; rdfs:range :Participant ; rdfs:label "profile of"@en ; rdfs:comment "Relates a demographic profile to the participant it describes."@en .
:hasDatasetRecord a owl:ObjectProperty ; rdfs:domain :StressExperiment ; rdfs:range :DatasetRecord ; rdfs:label "has dataset record"@en ; rdfs:comment "Relates a stress experiment to a dataset record."@en .
:recordedFromParticipant a owl:ObjectProperty ; rdfs:domain :DatasetRecord ; rdfs:range :Participant ; rdfs:label "recorded from participant"@en ; rdfs:comment "Relates a dataset record to the participant from whom it was recorded."@en .
:hasHeaderFile a owl:ObjectProperty ; rdfs:domain :DatasetRecord ; rdfs:range :HeaderFile ; rdfs:label "has header file"@en ; rdfs:comment "Relates a dataset record to its header metadata file."@en .
:hasBinarySignalFile a owl:ObjectProperty ; rdfs:domain :DatasetRecord ; rdfs:range :BinarySignalFile ; rdfs:label "has binary signal file"@en ; rdfs:comment "Relates a dataset record to its binary signal file."@en .
:hasAnnotationFile a owl:ObjectProperty ; rdfs:domain :DatasetRecord ; rdfs:range :AnnotationFile ; rdfs:label "has annotation file"@en ; rdfs:comment "Relates a dataset record to an annotation file."@en .
:hasSignalChannel a owl:ObjectProperty ; rdfs:domain :DatasetRecord ; rdfs:range :SignalChannel ; rdfs:label "has signal channel"@en ; rdfs:comment "Relates a dataset record to a sampled signal channel."@en .
:isSignalChannelOf a owl:ObjectProperty ; owl:inverseOf :hasSignalChannel ; rdfs:domain :SignalChannel ; rdfs:range :DatasetRecord ; rdfs:label "is signal channel of"@en ; rdfs:comment "Relates a signal channel to the dataset record containing it."@en .
:usesSensor a owl:ObjectProperty ; rdfs:domain :SignalChannel ; rdfs:range :Sensor ; rdfs:label "uses sensor"@en ; rdfs:comment "Relates a signal channel to the sensor type used to generate it."@en .
:observesProperty a owl:ObjectProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :Sensor :SignalChannel :SampleObservation ) ] ; rdfs:range :ObservableProperty ; rdfs:label "observes property"@en ; rdfs:comment "Relates a sensor, channel, or sample observation to the observable property it measures."@en .
:hasUnit a owl:ObjectProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :SignalChannel :SampleObservation ) ] ; rdfs:range :Unit ; rdfs:label "has unit"@en ; rdfs:comment "Relates a signal channel or observation to a value unit."@en .
:hasExperimentalPhase a owl:ObjectProperty ; rdfs:domain :DatasetRecord ; rdfs:range :ExperimentalPhase ; rdfs:label "has experimental phase"@en ; rdfs:comment "Relates a dataset record to an annotated experimental phase."@en .
:hasCondition a owl:ObjectProperty ; rdfs:domain :ExperimentalPhase ; rdfs:range :ExperimentalCondition ; rdfs:label "has condition"@en ; rdfs:comment "Relates an experimental phase to the condition label assigned to it."@en .
:belongsToRecord a owl:ObjectProperty ; rdfs:domain :SampleObservation ; rdfs:range :DatasetRecord ; rdfs:label "belongs to record"@en ; rdfs:comment "Relates a sample observation to the dataset record from which it comes."@en .
:belongsToChannel a owl:ObjectProperty ; rdfs:domain :SampleObservation ; rdfs:range :SignalChannel ; rdfs:label "belongs to channel"@en ; rdfs:comment "Relates a sample observation to the signal channel from which it comes."@en .
:hasObservation a owl:ObjectProperty ; rdfs:domain :SignalObservationCollection ; rdfs:range :SampleObservation ; rdfs:label "has observation"@en ; rdfs:comment "Relates an observation collection to a sampled observation."@en .

#################################################################
# Data properties
#################################################################

:participantIdentifier a owl:DatatypeProperty ; rdfs:domain :Participant ; rdfs:range xsd:string ; rdfs:label "participant identifier"@en ; rdfs:comment "A local identifier for a participant."@en .
:ageYears a owl:DatatypeProperty ; rdfs:domain :DemographicProfile ; rdfs:range xsd:integer ; rdfs:label "age in years"@en ; rdfs:comment "Age of the participant in years."@en .
:genderCode a owl:DatatypeProperty ; rdfs:domain :DemographicProfile ; rdfs:range xsd:string ; rdfs:label "gender code"@en ; rdfs:comment "Gender value as encoded in the dataset header."@en .
:heightCentimeters a owl:DatatypeProperty ; rdfs:domain :DemographicProfile ; rdfs:range xsd:decimal ; rdfs:label "height in centimeters"@en ; rdfs:comment "Height of the participant in centimeters."@en .
:weightKilograms a owl:DatatypeProperty ; rdfs:domain :DemographicProfile ; rdfs:range xsd:decimal ; rdfs:label "weight in kilograms"@en ; rdfs:comment "Weight of the participant in kilograms."@en .
:recordName a owl:DatatypeProperty ; rdfs:domain :DatasetRecord ; rdfs:range xsd:string ; rdfs:label "record name"@en ; rdfs:comment "The local name of a dataset record."@en .
:fileName a owl:DatatypeProperty ; rdfs:domain :RecordFile ; rdfs:range xsd:string ; rdfs:label "file name"@en ; rdfs:comment "The file name of a digital record file."@en .
:samplingFrequencyHertz a owl:DatatypeProperty ; rdfs:domain :DatasetRecord ; rdfs:range xsd:decimal ; rdfs:label "sampling frequency in hertz"@en ; rdfs:comment "The sampling frequency of a dataset record in hertz."@en .
:sampleCount a owl:DatatypeProperty ; rdfs:domain :DatasetRecord ; rdfs:range xsd:integer ; rdfs:label "sample count"@en ; rdfs:comment "The number of samples per channel in a dataset record."@en .
:channelCount a owl:DatatypeProperty ; rdfs:domain :DatasetRecord ; rdfs:range xsd:integer ; rdfs:label "channel count"@en ; rdfs:comment "The number of signal channels in a dataset record."@en .
:durationSeconds a owl:DatatypeProperty ; rdfs:domain :DatasetRecord ; rdfs:range xsd:decimal ; rdfs:label "duration in seconds"@en ; rdfs:comment "The approximate duration of a sampled dataset record in seconds."@en .
:channelName a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:string ; rdfs:label "channel name"@en ; rdfs:comment "The channel name as provided in the dataset header."@en .
:channelIndex a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:integer ; rdfs:label "channel index"@en ; rdfs:comment "The one-based position of the channel in the dataset record."@en .
:digitalFormat a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:string ; rdfs:label "digital format"@en ; rdfs:comment "The encoded digital signal format of a channel, such as 16-bit integer."@en .
:adcGain a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:decimal ; rdfs:label "ADC gain"@en ; rdfs:comment "The analog-to-digital conversion gain associated with a signal channel."@en .
:adcBaseline a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:integer ; rdfs:label "ADC baseline"@en ; rdfs:comment "The analog-to-digital conversion baseline associated with a signal channel."@en .
:adcResolutionBits a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:integer ; rdfs:label "ADC resolution bits"@en ; rdfs:comment "The analog-to-digital resolution in bits for a signal channel."@en .
:unitSymbol a owl:DatatypeProperty ; rdfs:domain :Unit ; rdfs:range xsd:string ; rdfs:label "unit symbol"@en ; rdfs:comment "A textual unit symbol, such as %, bpm, degC, or NU."@en .
:sampleIndex a owl:DatatypeProperty ; rdfs:domain :SampleObservation ; rdfs:range xsd:integer ; rdfs:label "sample index"@en ; rdfs:comment "The zero-based or local sample index represented by a sample observation."@en .
:digitalValue a owl:DatatypeProperty ; rdfs:domain :SampleObservation ; rdfs:range xsd:integer ; rdfs:label "digital value"@en ; rdfs:comment "A raw digital sample value."@en .
:physicalValue a owl:DatatypeProperty ; rdfs:domain :SampleObservation ; rdfs:range xsd:decimal ; rdfs:label "physical value"@en ; rdfs:comment "A sample value converted to the physical unit specified for the channel."@en .
:conditionLabel a owl:DatatypeProperty ; rdfs:domain :ExperimentalCondition ; rdfs:range xsd:string ; rdfs:label "condition label"@en ; rdfs:comment "The condition text label used in annotation data."@en .
:phaseOrder a owl:DatatypeProperty ; rdfs:domain :ExperimentalPhase ; rdfs:range xsd:integer ; rdfs:label "phase order"@en ; rdfs:comment "The sequence order of an experimental phase within an annotated record."@en .

#################################################################
# Restrictions
#################################################################

:DatasetRecord rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty :recordedFromParticipant ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :Participant ],
    [ a owl:Restriction ; owl:onProperty :hasHeaderFile ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :HeaderFile ],
    [ a owl:Restriction ; owl:onProperty :hasBinarySignalFile ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :BinarySignalFile ],
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :SignalChannel ] .

:AccelerometryTemperatureEdaRecord rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :XAxisAccelerationChannel ],
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :YAxisAccelerationChannel ],
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :ZAxisAccelerationChannel ],
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :TemperatureChannel ],
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :ElectrodermalActivityChannel ] .

:OxygenSaturationHeartRateRecord rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :OxygenSaturationChannel ],
    [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :HeartRateChannel ] .

:SampleObservation rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty :belongsToChannel ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :SignalChannel ],
    [ a owl:Restriction ; owl:onProperty :belongsToRecord ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :DatasetRecord ],
    [ a owl:Restriction ; owl:onProperty :observesProperty ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :ObservableProperty ] .

:ExperimentalPhase rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty :hasCondition ; owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; owl:onClass :ExperimentalCondition ] .

#################################################################
# Individuals: units, observable properties, sensors, conditions
#################################################################

:NoUnit a owl:NamedIndividual, :Unit ; rdfs:label "No unit"@en ; rdfs:comment "A unit marker used for normalized or unspecified numeric channels encoded as NU in the source files."@en ; :unitSymbol "NU" .
:DegreeCelsius a owl:NamedIndividual, :Unit ; rdfs:label "degree Celsius"@en ; rdfs:comment "Temperature unit degree Celsius."@en ; :unitSymbol "degC" .
:Percent a owl:NamedIndividual, :Unit ; rdfs:label "percent"@en ; rdfs:comment "Percentage unit used for oxygen saturation."@en ; :unitSymbol "%" .
:BeatsPerMinute a owl:NamedIndividual, :Unit ; rdfs:label "beats per minute"@en ; rdfs:comment "Unit used for heart rate."@en ; :unitSymbol "bpm" .

:XAccelerationProperty a owl:NamedIndividual, :XAxisAcceleration ; rdfs:label "x-axis acceleration property"@en .
:YAccelerationProperty a owl:NamedIndividual, :YAxisAcceleration ; rdfs:label "y-axis acceleration property"@en .
:ZAccelerationProperty a owl:NamedIndividual, :ZAxisAcceleration ; rdfs:label "z-axis acceleration property"@en .
:TemperatureProperty a owl:NamedIndividual, :BodyTemperature ; rdfs:label "temperature property"@en .
:EdaProperty a owl:NamedIndividual, :ElectrodermalActivity ; rdfs:label "electrodermal activity property"@en .
:SpO2Property a owl:NamedIndividual, :PeripheralOxygenSaturation ; rdfs:label "peripheral oxygen saturation property"@en .
:HeartRateProperty a owl:NamedIndividual, :HeartRate ; rdfs:label "heart rate property"@en .

:AccelerometerSensor a owl:NamedIndividual, :Accelerometer ; rdfs:label "accelerometer sensor"@en ; sosa:observes :XAccelerationProperty, :YAccelerationProperty, :ZAccelerationProperty ; :observesProperty :XAccelerationProperty, :YAccelerationProperty, :ZAccelerationProperty .
:TemperatureSensor a owl:NamedIndividual, :TemperatureSensorClass ; rdfs:label "temperature sensor"@en ; sosa:observes :TemperatureProperty ; :observesProperty :TemperatureProperty .
:EdaSensor a owl:NamedIndividual, :ElectrodermalActivitySensor ; rdfs:label "EDA sensor"@en ; sosa:observes :EdaProperty ; :observesProperty :EdaProperty .
:PulseOximeterSensor a owl:NamedIndividual, :PulseOximeter ; rdfs:label "pulse oximeter sensor"@en ; sosa:observes :SpO2Property ; :observesProperty :SpO2Property .
:HeartRateSensor a owl:NamedIndividual, :HeartRateSensorClass ; rdfs:label "heart rate sensor"@en ; sosa:observes :HeartRateProperty ; :observesProperty :HeartRateProperty .

:Relax a owl:NamedIndividual, :RelaxCondition ; rdfs:label "Relax"@en ; :conditionLabel "Relax" .
:PhysicalStress a owl:NamedIndividual, :PhysicalStressCondition ; rdfs:label "Physical stress"@en ; :conditionLabel "PhysicalStress" .
:EmotionalStress a owl:NamedIndividual, :EmotionalStressCondition ; rdfs:label "Emotional stress"@en ; :conditionLabel "EmotionalStress" .
:CognitiveStress a owl:NamedIndividual, :CognitiveStressCondition ; rdfs:label "Cognitive stress"@en ; :conditionLabel "CognitiveStress" .

#################################################################
# Experiment and participants
#################################################################

:StressExperimentDataset a owl:NamedIndividual, :StressExperiment ;
    rdfs:label "Stress experiment dataset"@en ;
    rdfs:comment "The generated stress experiment dataset collection represented by the uploaded example files."@en ;
    :hasParticipant :Subject1, :Subject2, :Subject3, :Subject4 ;
    :hasDatasetRecord :Subject1_AccTempEDA_Record, :Subject1_SpO2HR_Record, :Subject2_AccTempEDA_Record, :Subject2_SpO2HR_Record, :Subject3_AccTempEDA_Record, :Subject3_SpO2HR_Record, :Subject4_AccTempEDA_Record, :Subject4_SpO2HR_Record .

:Subject1 a owl:NamedIndividual, :Participant ; rdfs:label "Subject 1"@en ; :participantIdentifier "Subject1" ; :hasDemographicProfile :Subject1_DemographicProfile .
:Subject1_DemographicProfile a owl:NamedIndividual, :DemographicProfile ; rdfs:label "Subject 1 demographic profile"@en ; :ageYears 30 ; :genderCode "M" ; :heightCentimeters 177 ; :weightKilograms 94 .
:Subject2 a owl:NamedIndividual, :Participant ; rdfs:label "Subject 2"@en ; :participantIdentifier "Subject2" ; :hasDemographicProfile :Subject2_DemographicProfile .
:Subject2_DemographicProfile a owl:NamedIndividual, :DemographicProfile ; rdfs:label "Subject 2 demographic profile"@en ; :ageYears 28 ; :genderCode "M" ; :heightCentimeters 172 ; :weightKilograms 68 .
:Subject3 a owl:NamedIndividual, :Participant ; rdfs:label "Subject 3"@en ; :participantIdentifier "Subject3" ; :hasDemographicProfile :Subject3_DemographicProfile .
:Subject3_DemographicProfile a owl:NamedIndividual, :DemographicProfile ; rdfs:label "Subject 3 demographic profile"@en ; :ageYears 28 ; :genderCode "M" ; :heightCentimeters 177 ; :weightKilograms 91 .
:Subject4 a owl:NamedIndividual, :Participant ; rdfs:label "Subject 4"@en ; :participantIdentifier "Subject4" ; :hasDemographicProfile :Subject4_DemographicProfile .
:Subject4_DemographicProfile a owl:NamedIndividual, :DemographicProfile ; rdfs:label "Subject 4 demographic profile"@en ; :ageYears 22 ; :genderCode "M" ; :heightCentimeters 167 ; :weightKilograms 58 .

#################################################################
