:Person rdf:type owl:Class ;
        rdfs:label "Person"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/PhysicalStressPhase
:PhysicalStressPhase rdf:type owl:Class ;
                     rdfs:subClassOf :Activity ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :hasStressCondition ;
                                       owl:someValuesFrom :PhysicalStressor
                                     ] ;
                     rdfs:comment "A phase labeled as physical stress."@en ;
                     rdfs:label "Physical Stress Phase"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/PhysicalStressor
:PhysicalStressor rdf:type owl:Class ;
                  rdfs:subClassOf :AcuteStressor ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasAssociatedActivity ;
                                    owl:someValuesFrom :PhysicalStressPhase
                                  ] ;
                  rdfs:comment "An acute stressor associated with physical stress tasks or phases."@en ;
                  rdfs:label "Physical Stressor"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/PhysiologicalProperty
:PhysiologicalProperty rdf:type owl:Class ;
                       rdfs:subClassOf sosa:ObservableProperty ;
                       rdfs:label "Physiological Property"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/PhysiologicalRecord
:PhysiologicalRecord rdf:type owl:Class ;
                     rdfs:comment "A data record containing one or more physiological or wearable signal channels."@en ;
                     rdfs:label "Physiological Record"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/PhysiologicalSensor
:PhysiologicalSensor rdf:type owl:Class ;
                     rdfs:subClassOf sosa:Sensor ;
                     rdfs:comment "A sensor used to measure physiological properties or bodily signals."@en ;
                     rdfs:label "Physiological Sensor"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/RelaxationCondition
:RelaxationCondition rdf:type owl:Class ;
                     rdfs:subClassOf :NoStressCondition ;
                     rdfs:comment "A no-stress condition representing relaxation or recovery between stress-inducing phases."@en ;
                     rdfs:label "Relaxation Condition"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/RelaxationPhase
:RelaxationPhase rdf:type owl:Class ;
                 rdfs:subClassOf :Activity ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasStressCondition ;
                                   owl:someValuesFrom :RelaxationCondition
                                 ] ;
                 rdfs:comment "A no-stress relaxation or recovery phase that can occur between stress-inducing phases."@en ;
                 rdfs:label "Relaxation Phase"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/SignalChannel
:SignalChannel rdf:type owl:Class ;
               rdfs:comment "A single signal channel within a physiological or wearable data record."@en ;
               rdfs:label "Signal Channel"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/SkinTemperature
:SkinTemperature rdf:type owl:Class ;
                 rdfs:subClassOf :PhysiologicalProperty ;
                 rdfs:comment "Skin or body-surface temperature as a physiological observable property."@en ;
                 rdfs:label "SkinTemperature"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/SocioEvaluativePhase
:SocioEvaluativePhase rdf:type owl:Class ;
                      rdfs:subClassOf :Activity ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :hasStressCondition ;
                                        owl:someValuesFrom :SocioEvaluativeStressor
                                      ] ;
                      rdfs:comment "A phase labeled as socio-evaluative stress."@en ;
                      rdfs:label "Socio-Evaluative Stress Phase"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/SocioEvaluativeStressor
:SocioEvaluativeStressor rdf:type owl:Class ;
                         rdfs:subClassOf :AcuteStressor ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :hasAssociatedActivity ;
                                           owl:someValuesFrom :SocioEvaluativePhase
                                         ] ;
                         rdfs:comment "An acute stressor associated with socio-evaluative stress tasks or phases."@en ;
                         rdfs:label "Socio-Evaluative Stressor"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/SpO2Sensor
:SpO2Sensor rdf:type owl:Class ;
            rdfs:subClassOf :PPGSensor ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty sosa:observes ;
                              owl:someValuesFrom :BloodOxygenSaturation
                            ] ;
            rdfs:comment "A PPG-based sensor used to measure peripheral oxygen saturation."@en ;
            rdfs:label "SpO2 Sensor"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/StressCondition
:StressCondition rdf:type owl:Class ;
                 rdfs:comment "A condition describing whether stress is induced, absent, or represented by a specific stressor context."@en ;
                 rdfs:label "Stress Condition"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/Stressor
:Stressor rdf:type owl:Class ;
          rdfs:subClassOf :StressCondition ;
          rdfs:comment "A condition, event, stimulus, or situation that can induce stress."@en ;
          rdfs:label "Stressor"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/Subject
:Subject rdf:type owl:Class ;
         rdfs:subClassOf :Person ,
                         sosa:FeatureOfInterest ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty schema:diagnosis ;
                           owl:allValuesFrom schema:MedicalCondition
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty schema:drug ;
                           owl:allValuesFrom schema:Drug
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty schema:healthCondition ;
                           owl:allValuesFrom schema:MedicalCondition
                         ] ;
         rdfs:comment "A study subject represented as a person with patient-related Schema.org properties."@en ;
         rdfs:label "Subject"@en ;
         rdfs:seeAlso schema:Patient ,
                      "https://schema.org/Patient" .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/TemperatureSensor
:TemperatureSensor rdf:type owl:Class ;
                   rdfs:subClassOf :PhysiologicalSensor ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty sosa:observes ;
                                     owl:someValuesFrom :SkinTemperature
                                   ] ;
                   rdfs:comment "A physiological sensor used to measure skin or body-surface temperature."@en ;
                   rdfs:label "Temperature Sensor"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/TimeSeriesObservation
:TimeSeriesObservation rdf:type owl:Class ;
                       rdfs:subClassOf sosa:Observation ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasTimestamp ;
                                         owl:allValuesFrom xsd:dateTime
                                       ] ;
                       rdfs:comment "An observation derived from a physiological time-series signal. Time-series observations can be associated with timestamps using hasTimestamp."@en ;
                       rdfs:label "TimeSeriesObservation"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/VideoCamera
:VideoCamera rdf:type owl:Class ;
             rdfs:subClassOf :CameraSensor ;
             rdfs:comment "A video camera used as a visual sensor in a stress experiment."@en ;
             rdfs:label "Video Camera"@en .


###  http://www.semanticweb.org/lennart/ontologies/2026/4/WISDOM-Stress/WearableDevice
:WearableDevice rdf:type owl:Class ;
                rdfs:subClassOf sosa:Platform ;
                rdfs:comment "A wearable platform that can host physiological or motion sensors."@en ;
                rdfs:label "Wearable Device"@en .


