#################################################################
# Biomarker assay representation pattern
#################################################################

:ExampleSalivaryCortisolSample a owl:NamedIndividual, :BiologicalSample ;
    rdfs:label "example salivary cortisol sample"@en ;
    sosa:isSampleOf :Subject1 .

:ExampleCortisolAssay a owl:NamedIndividual, :BiomarkerAssay ;
    rdfs:label "example cortisol assay"@en ;
    :biomarkerName "cortisol" ;
    :assayUsesSample :ExampleSalivaryCortisolSample ;
    rdfs:comment "Example pattern showing how a biomarker assay can be represented when assay data are available."@en .

:ExampleCortisolObservation a owl:NamedIndividual, :BiomarkerObservation ;
    rdfs:label "example cortisol observation"@en ;
    sosa:hasFeatureOfInterest :Subject1 ;
    :basedOnAssay :ExampleCortisolAssay ;
    :observedDuringActivity :Subject1_PhysicalStress ;
    rdfs:comment "Example pattern showing how an observation can be linked to a biomarker assay."@en .
