@base <http://example.org/generated-stress-combined#> .
@prefix : <http://example.org/generated-stress-combined#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa: <https://www.w3.org/ns/sosa/> .
@prefix ssn: <https://www.w3.org/ns/ssn/> .
@prefix schema: <https://schema.org/> .

<http://example.org/generated-stress-combined>
    a owl:Ontology ;
    rdfs:label "Generated combined wearable stress experiment ontology"@en ;
    rdfs:comment "OWL 2 ontology for human stress in wearable- and sensor-based stress experiment data. It combines SOSA/SSN-style observation modeling, schema.org-compatible persons, competency-question-driven concepts, and WFDB-like example records for acceleration, temperature, EDA, SpO2, and heart rate."@en ;
    owl:versionInfo "1.0.1" .

#################################################################
# Core classes
#################################################################

:HumanParticipant a owl:Class ; rdfs:subClassOf schema:Person, sosa:FeatureOfInterest ; rdfs:label "Human participant"@en ; rdfs:comment "A human person participating in a stress experiment."@en .
:Subject a owl:Class ; rdfs:subClassOf :HumanParticipant, [ a owl:Restriction ; owl:onProperty :hasRole ; owl:someValuesFrom :SubjectRole ] ; rdfs:label "Subject"@en ; rdfs:comment "A participant whose physiological, movement, behavioral, or contextual data are collected."@en .
:PatientSubject a owl:Class ; rdfs:subClassOf :Subject, schema:Patient ; rdfs:label "Patient subject"@en ; rdfs:comment "A subject represented compatibly with schema.org Patient where a patient-oriented interpretation is needed."@en .
:Observer a owl:Class ; rdfs:subClassOf :HumanParticipant, [ a owl:Restriction ; owl:onProperty :hasRole ; owl:someValuesFrom :ObserverRole ] ; rdfs:label "Observer"@en ; rdfs:comment "A human source of annotations or human observations."@en .
:PersonRole a owl:Class ; rdfs:label "Person role"@en ; rdfs:comment "A role taken by a person in a stress experiment."@en .
:SubjectRole a owl:Class ; rdfs:subClassOf :PersonRole ; rdfs:label "Subject role"@en ; rdfs:comment "Role of a measured person."@en .
:ObserverRole a owl:Class ; rdfs:subClassOf :PersonRole ; rdfs:label "Observer role"@en ; rdfs:comment "Role of a person producing an annotation or human observation."@en .
:ExperimenterRole a owl:Class ; rdfs:subClassOf :ObserverRole ; rdfs:label "Experimenter role"@en ; rdfs:comment "Role of a person conducting or supervising an experiment."@en .

:StressExperiment a owl:Class ; rdfs:subClassOf sosa:Procedure ; rdfs:label "Stress experiment"@en ; rdfs:comment "A procedure organizing stress-related phases, stressors, sensors, observations, and annotations."@en .
:ExperimentSession a owl:Class ; rdfs:label "Experiment session"@en ; rdfs:comment "A concrete session of a subject in a stress experiment."@en .
:ExperimentalActivity a owl:Class ; rdfs:label "Experimental activity"@en ; rdfs:comment "An activity or phase during which data are collected."@en .
:ExperimentalPhase a owl:Class ; rdfs:subClassOf :ExperimentalActivity ; rdfs:label "Experimental phase"@en ; rdfs:comment "A temporally delimited phase of a stress experiment."@en .
:RelaxPhase a owl:Class ; rdfs:subClassOf :ExperimentalPhase, [ a owl:Restriction ; owl:onProperty :hasStressCondition ; owl:hasValue :relaxCondition ] ; rdfs:label "Relax phase"@en ; rdfs:comment "A phase annotated as relaxation, baseline, or recovery."@en .
:PhysicalStressPhase a owl:Class ; rdfs:subClassOf :ExperimentalPhase, [ a owl:Restriction ; owl:onProperty :hasStressCondition ; owl:hasValue :physicalStressCondition ], [ a owl:Restriction ; owl:onProperty :hasStressor ; owl:someValuesFrom :PhysicalStressor ] ; rdfs:label "Physical stress phase"@en ; rdfs:comment "A phase associated with physical stress."@en .
:EmotionalStressPhase a owl:Class ; rdfs:subClassOf :ExperimentalPhase, [ a owl:Restriction ; owl:onProperty :hasStressCondition ; owl:hasValue :emotionalStressCondition ], [ a owl:Restriction ; owl:onProperty :hasStressor ; owl:someValuesFrom :EmotionalStressor ] ; rdfs:label "Emotional stress phase"@en ; rdfs:comment "A phase associated with emotional stress."@en .
:CognitiveStressPhase a owl:Class ; rdfs:subClassOf :ExperimentalPhase, [ a owl:Restriction ; owl:onProperty :hasStressCondition ; owl:hasValue :cognitiveStressCondition ], [ a owl:Restriction ; owl:onProperty :hasStressor ; owl:someValuesFrom :CognitiveStressor ] ; rdfs:label "Cognitive stress phase"@en ; rdfs:comment "A phase associated with cognitive stress."@en .

:StressRelatedCondition a owl:Class ; rdfs:label "Stress-related condition"@en ; rdfs:comment "A condition describing a subject's stress-related state."@en .
:StressCondition a owl:Class ; rdfs:subClassOf :StressRelatedCondition ; rdfs:label "Stress condition"@en ; rdfs:comment "A condition representing stress exposure or response."@en .
:ShortTermStressCondition a owl:Class ; rdfs:subClassOf :StressCondition ; rdfs:label "Short-term stress condition"@en ; rdfs:comment "An acute stress condition during a bounded phase."@en .
:PhysicalStressCondition a owl:Class ; rdfs:subClassOf :ShortTermStressCondition ; rdfs:label "Physical stress condition"@en ; rdfs:comment "A short-term stress condition involving physical load."@en .
:EmotionalStressCondition a owl:Class ; rdfs:subClassOf :ShortTermStressCondition ; rdfs:label "Emotional stress condition"@en ; rdfs:comment "A short-term stress condition involving emotional stimulation."@en .
:CognitiveStressCondition a owl:Class ; rdfs:subClassOf :ShortTermStressCondition ; rdfs:label "Cognitive stress condition"@en ; rdfs:comment "A short-term stress condition involving cognitive demand."@en .
:NonStressCondition a owl:Class ; rdfs:subClassOf :StressRelatedCondition ; rdfs:label "Non-stress condition"@en ; rdfs:comment "A condition not primarily characterized by stress exposure."@en .
:RelaxCondition a owl:Class ; rdfs:subClassOf :NonStressCondition ; rdfs:label "Relax condition"@en ; rdfs:comment "A relaxed condition."@en .
:BaselineCondition a owl:Class ; rdfs:subClassOf :NonStressCondition ; rdfs:label "Baseline condition"@en ; rdfs:comment "A reference condition before or between stress phases."@en .
:RecoveryCondition a owl:Class ; rdfs:subClassOf :NonStressCondition ; rdfs:label "Recovery condition"@en ; rdfs:comment "A condition representing recovery after stress exposure."@en .

:Stressor a owl:Class ; rdfs:label "Stressor"@en ; rdfs:comment "A stimulus, task, or contextual factor associated with stress."@en .
:ShortTermStressor a owl:Class ; rdfs:subClassOf :Stressor ; rdfs:label "Short-term stressor"@en ; rdfs:comment "A bounded stressor occurring during an activity phase."@en .
:PhysicalStressor a owl:Class ; rdfs:subClassOf :ShortTermStressor ; rdfs:label "Physical stressor"@en ; rdfs:comment "A stressor involving physical load or movement."@en .
:EmotionalStressor a owl:Class ; rdfs:subClassOf :ShortTermStressor ; rdfs:label "Emotional stressor"@en ; rdfs:comment "A stressor involving emotional stimulation."@en .
:CognitiveStressor a owl:Class ; rdfs:subClassOf :ShortTermStressor ; rdfs:label "Cognitive stressor"@en ; rdfs:comment "A stressor involving cognitive demand."@en .

:SensorType a owl:Class ; rdfs:label "Sensor type"@en ; rdfs:comment "A sensor category used for stress-related measurements."@en .
:PhysiologicalSensor a owl:Class ; rdfs:subClassOf sosa:Sensor ; rdfs:label "Physiological sensor"@en ; rdfs:comment "A sensor observing physiological properties."@en .
:MovementSensor a owl:Class ; rdfs:subClassOf sosa:Sensor ; rdfs:label "Movement sensor"@en ; rdfs:comment "A sensor observing movement-related properties."@en .
:HeartRateSensor a owl:Class ; rdfs:subClassOf :PhysiologicalSensor, [ a owl:Restriction ; owl:onProperty sosa:observes ; owl:hasValue :heartRate ] ; rdfs:label "Heart rate sensor"@en ; rdfs:comment "A sensor measuring heart rate."@en .
:EDASensor a owl:Class ; rdfs:subClassOf :PhysiologicalSensor, [ a owl:Restriction ; owl:onProperty sosa:observes ; owl:hasValue :electrodermalActivity ] ; rdfs:label "EDA sensor"@en ; rdfs:comment "A sensor measuring electrodermal activity."@en .
:SpO2Sensor a owl:Class ; rdfs:subClassOf :PhysiologicalSensor, [ a owl:Restriction ; owl:onProperty sosa:observes ; owl:hasValue :bloodOxygenSaturation ] ; rdfs:label "SpO2 sensor"@en ; rdfs:comment "A sensor measuring peripheral oxygen saturation."@en .
:TemperatureSensor a owl:Class ; rdfs:subClassOf :PhysiologicalSensor, [ a owl:Restriction ; owl:onProperty sosa:observes ; owl:hasValue :skinTemperature ] ; rdfs:label "Temperature sensor"@en ; rdfs:comment "A sensor measuring skin or body temperature."@en .
:Accelerometer a owl:Class ; rdfs:subClassOf :MovementSensor ; rdfs:label "Accelerometer"@en ; rdfs:comment "A movement sensor measuring acceleration-related properties."@en .
:MeasurementPlatform a owl:Class ; rdfs:subClassOf sosa:Platform ; rdfs:label "Measurement platform"@en ; rdfs:comment "A device or platform hosting sensors."@en .
:WearableDevice a owl:Class ; rdfs:subClassOf :MeasurementPlatform ; rdfs:label "Wearable device"@en ; rdfs:comment "A measurement platform worn by a human participant."@en .

:MeasurableProperty a owl:Class ; rdfs:subClassOf sosa:ObservableProperty ; rdfs:label "Measurable property"@en ; rdfs:comment "A property that can be observed or measured."@en .
:PhysiologicalProperty a owl:Class ; rdfs:subClassOf :MeasurableProperty ; rdfs:label "Physiological property"@en ; rdfs:comment "A measurable body property relevant to stress."@en .
:MovementProperty a owl:Class ; rdfs:subClassOf :MeasurableProperty ; rdfs:label "Movement property"@en ; rdfs:comment "A measurable property describing movement or acceleration."@en .
:BehavioralIndicator a owl:Class ; rdfs:subClassOf :MeasurableProperty ; rdfs:label "Behavioral indicator"@en ; rdfs:comment "A measurable or annotatable behavioral indicator."@en .
:EnvironmentalProperty a owl:Class ; rdfs:subClassOf :MeasurableProperty ; rdfs:label "Environmental property"@en ; rdfs:comment "A measurable contextual property of an environment."@en .

:PhysiologicalRecord a owl:Class ; rdfs:label "Physiological record"@en ; rdfs:comment "A WFDB-like record containing signal channels and metadata."@en .
:SignalChannel a owl:Class ; rdfs:label "Signal channel"@en ; rdfs:comment "A named signal stream in a physiological record."@en .
:SourceDataFile a owl:Class ; rdfs:label "Source data file"@en ; rdfs:comment "A file storing raw signals, metadata, or annotations."@en .
:HeaderFile a owl:Class ; rdfs:subClassOf :SourceDataFile ; rdfs:label "Header file"@en ; rdfs:comment "A source file containing record and channel metadata."@en .
:SignalDataFile a owl:Class ; rdfs:subClassOf :SourceDataFile ; rdfs:label "Signal data file"@en ; rdfs:comment "A source file containing sampled signal values."@en .
:AnnotationFile a owl:Class ; rdfs:subClassOf :SourceDataFile ; rdfs:label "Annotation file"@en ; rdfs:comment "A source file containing phase or condition annotations."@en .

:StressObservation a owl:Class ; rdfs:subClassOf sosa:Observation ; rdfs:label "Stress observation"@en ; rdfs:comment "An observation made in a stress-related experimental context."@en .
:TimeSeriesObservation a owl:Class ; rdfs:subClassOf :StressObservation, [ a owl:Restriction ; owl:onProperty :hasSourceRecord ; owl:someValuesFrom :PhysiologicalRecord ], [ a owl:Restriction ; owl:onProperty :hasSignalChannel ; owl:someValuesFrom :SignalChannel ] ; rdfs:label "Time-series observation"@en ; rdfs:comment "An observation derived from a time-indexed signal channel."@en .
:PhysiologicalObservation a owl:Class ; rdfs:subClassOf :TimeSeriesObservation ; rdfs:label "Physiological observation"@en ; rdfs:comment "A time-series observation of a physiological property."@en .
:MovementObservation a owl:Class ; rdfs:subClassOf :TimeSeriesObservation ; rdfs:label "Movement observation"@en ; rdfs:comment "A time-series observation of a movement-related property."@en .
:EnvironmentalObservation a owl:Class ; rdfs:subClassOf :StressObservation ; rdfs:label "Environmental observation"@en ; rdfs:comment "An observation of an environmental property."@en .
:HumanObservation a owl:Class ; rdfs:subClassOf :StressObservation ; rdfs:label "Human observation"@en ; rdfs:comment "An observation whose source is a human observer."@en .
:StressAnnotation a owl:Class ; rdfs:label "Stress annotation"@en ; rdfs:comment "An annotation assigning labels, stress conditions, or phase information to data."@en .
:Environment a owl:Class ; rdfs:subClassOf sosa:FeatureOfInterest ; rdfs:label "Environment"@en ; rdfs:comment "The environmental context of a stress experiment."@en .
:BiomarkerAssay a owl:Class ; rdfs:subClassOf sosa:Procedure ; rdfs:label "Biomarker assay"@en ; rdfs:comment "An assay procedure used to measure a stress-related biomarker."@en .
:BiomarkerObservation a owl:Class ; rdfs:subClassOf :StressObservation, [ a owl:Restriction ; owl:onProperty :basedOnAssay ; owl:someValuesFrom :BiomarkerAssay ] ; rdfs:label "Biomarker observation"@en ; rdfs:comment "An observation linked to a biomarker assay."@en .
:BiologicalSample a owl:Class ; rdfs:subClassOf sosa:Sample ; rdfs:label "Biological sample"@en ; rdfs:comment "A sample taken from a participant for biomarker assay purposes."@en .

#################################################################
# Object properties
#################################################################

:hasRole a owl:ObjectProperty ; rdfs:domain schema:Person ; rdfs:range :PersonRole ; rdfs:label "has role"@en ; rdfs:comment "Connects a person to a role."@en .
:hasSession a owl:ObjectProperty ; rdfs:domain :HumanParticipant ; rdfs:range :ExperimentSession ; rdfs:label "has session"@en ; rdfs:comment "Connects a participant to an experiment session."@en .
:hasSubject a owl:ObjectProperty ; rdfs:domain :ExperimentSession ; rdfs:range :Subject ; rdfs:label "has subject"@en ; rdfs:comment "Connects a session to the measured subject."@en .
:usesProcedure a owl:ObjectProperty ; rdfs:domain :ExperimentSession ; rdfs:range :StressExperiment ; rdfs:label "uses procedure"@en ; rdfs:comment "Connects a session to the experiment procedure used."@en .
:hasActivity a owl:ObjectProperty ; rdfs:domain :ExperimentSession ; rdfs:range :ExperimentalActivity ; rdfs:label "has activity"@en ; rdfs:comment "Connects a session to an activity or phase."@en .
:nextActivity a owl:ObjectProperty ; rdfs:domain :ExperimentalActivity ; rdfs:range :ExperimentalActivity ; rdfs:label "next activity"@en ; rdfs:comment "Connects a phase to its subsequent phase."@en .
:hasStressCondition a owl:ObjectProperty ; rdfs:domain :ExperimentalActivity ; rdfs:range :StressRelatedCondition ; rdfs:label "has stress condition"@en ; rdfs:comment "Assigns a stress-related condition to an activity."@en .
:hasStressor a owl:ObjectProperty ; rdfs:domain :ExperimentalActivity ; rdfs:range :Stressor ; rdfs:label "has stressor"@en ; rdfs:comment "Assigns a stressor to an activity."@en .
:performedBy a owl:ObjectProperty ; rdfs:domain :ExperimentalActivity ; rdfs:range :Subject ; rdfs:label "performed by"@en ; rdfs:comment "Connects an activity to the subject experiencing it."@en .
:hostedOnPlatform a owl:ObjectProperty ; rdfs:subPropertyOf sosa:isHostedBy ; rdfs:domain sosa:Sensor ; rdfs:range sosa:Platform ; rdfs:label "hosted on platform"@en ; rdfs:comment "Connects a sensor to its platform."@en .
:recordedForSubject a owl:ObjectProperty ; rdfs:domain :PhysiologicalRecord ; rdfs:range :Subject ; rdfs:label "recorded for subject"@en ; rdfs:comment "Connects a record to the represented subject."@en .
:hasSignalChannel a owl:ObjectProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :PhysiologicalRecord :TimeSeriesObservation ) ] ; rdfs:range :SignalChannel ; rdfs:label "has signal channel"@en ; rdfs:comment "Connects a record or observation to a signal channel."@en .
:channelMeasures a owl:ObjectProperty ; rdfs:domain :SignalChannel ; rdfs:range :MeasurableProperty ; rdfs:label "channel measures"@en ; rdfs:comment "Specifies the measured property of a signal channel."@en .
:recordMeasuredBy a owl:ObjectProperty ; rdfs:domain :PhysiologicalRecord ; rdfs:range sosa:Sensor ; rdfs:label "record measured by"@en ; rdfs:comment "Connects a record to sensors involved in producing it."@en .
:hasSourceDataFile a owl:ObjectProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :PhysiologicalRecord :StressAnnotation :StressObservation ) ] ; rdfs:range :SourceDataFile ; rdfs:label "has source data file"@en ; rdfs:comment "Connects a record, annotation, or observation to a source file."@en .
:hasSourceRecord a owl:ObjectProperty ; rdfs:domain sosa:Observation ; rdfs:range :PhysiologicalRecord ; rdfs:label "has source record"@en ; rdfs:comment "Connects an observation to its source record."@en .
:observedDuringActivity a owl:ObjectProperty ; rdfs:domain sosa:Observation ; rdfs:range :ExperimentalActivity ; rdfs:label "observed during activity"@en ; rdfs:comment "Connects an observation to the activity during which it was made."@en .
:annotatesActivity a owl:ObjectProperty ; rdfs:domain :StressAnnotation ; rdfs:range :ExperimentalActivity ; rdfs:label "annotates activity"@en ; rdfs:comment "Connects an annotation to the activity it describes."@en .
:annotatesCondition a owl:ObjectProperty ; rdfs:domain :StressAnnotation ; rdfs:range :StressRelatedCondition ; rdfs:label "annotates condition"@en ; rdfs:comment "Connects an annotation to a stress-related condition."@en .
:hasObserver a owl:ObjectProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :StressAnnotation :HumanObservation ) ] ; rdfs:range :Observer ; rdfs:label "has observer"@en ; rdfs:comment "Connects an annotation or human observation to its human source."@en .
:hasEnvironment a owl:ObjectProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :ExperimentSession :ExperimentalActivity ) ] ; rdfs:range :Environment ; rdfs:label "has environment"@en ; rdfs:comment "Connects a session or activity to its environment."@en .
:basedOnAssay a owl:ObjectProperty ; rdfs:domain :BiomarkerObservation ; rdfs:range :BiomarkerAssay ; rdfs:label "based on assay"@en ; rdfs:comment "Connects a biomarker observation to its assay procedure."@en .
:assayUsesSample a owl:ObjectProperty ; rdfs:domain :BiomarkerAssay ; rdfs:range :BiologicalSample ; rdfs:label "assay uses sample"@en ; rdfs:comment "Connects a biomarker assay to the biological sample used."@en .

#################################################################
# Data properties
#################################################################

:subjectIdentifier a owl:DatatypeProperty ; rdfs:domain :Subject ; rdfs:range xsd:string ; rdfs:label "subject identifier"@en ; rdfs:comment "Identifier of a subject in the dataset."@en .
:ageYears a owl:DatatypeProperty ; rdfs:domain :Subject ; rdfs:range xsd:integer ; rdfs:label "age in years"@en ; rdfs:comment "Subject age in years."@en .
:genderCode a owl:DatatypeProperty ; rdfs:domain :Subject ; rdfs:range xsd:string ; rdfs:label "gender code"@en ; rdfs:comment "Dataset-provided gender code."@en .
:heightCm a owl:DatatypeProperty ; rdfs:domain :Subject ; rdfs:range xsd:decimal ; rdfs:label "height in centimetres"@en ; rdfs:comment "Subject height in centimetres."@en .
:weightKg a owl:DatatypeProperty ; rdfs:domain :Subject ; rdfs:range xsd:decimal ; rdfs:label "weight in kilograms"@en ; rdfs:comment "Subject weight in kilograms."@en .
:activityLabel a owl:DatatypeProperty ; rdfs:domain :ExperimentalActivity ; rdfs:range xsd:string ; rdfs:label "activity label"@en ; rdfs:comment "Dataset or annotation label of an activity."@en .
:sequenceIndex a owl:DatatypeProperty ; rdfs:domain :ExperimentalActivity ; rdfs:range xsd:integer ; rdfs:label "sequence index"@en ; rdfs:comment "Ordinal position of an activity."@en .
:startSampleIndex a owl:DatatypeProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :ExperimentalActivity :StressAnnotation :TimeSeriesObservation ) ] ; rdfs:range xsd:integer ; rdfs:label "start sample index"@en ; rdfs:comment "Sample index at which an entity starts."@en .
:endSampleIndex a owl:DatatypeProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :ExperimentalActivity :StressAnnotation :TimeSeriesObservation ) ] ; rdfs:range xsd:integer ; rdfs:label "end sample index"@en ; rdfs:comment "Sample index at which an entity ends."@en .
:startTime a owl:DatatypeProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :ExperimentalActivity :StressAnnotation :BiomarkerAssay :TimeSeriesObservation ) ] ; rdfs:range xsd:dateTime ; rdfs:label "start time"@en ; rdfs:comment "Start time when available."@en .
:endTime a owl:DatatypeProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( :ExperimentalActivity :StressAnnotation :TimeSeriesObservation ) ] ; rdfs:range xsd:dateTime ; rdfs:label "end time"@en ; rdfs:comment "End time when available."@en .
:recordName a owl:DatatypeProperty ; rdfs:domain :PhysiologicalRecord ; rdfs:range xsd:string ; rdfs:label "record name"@en ; rdfs:comment "Name of a physiological record."@en .
:signalCount a owl:DatatypeProperty ; rdfs:domain :PhysiologicalRecord ; rdfs:range xsd:integer ; rdfs:label "signal count"@en ; rdfs:comment "Number of signal channels."@en .
:recordSamplingFrequency a owl:DatatypeProperty ; rdfs:domain :PhysiologicalRecord ; rdfs:range xsd:decimal ; rdfs:label "record sampling frequency"@en ; rdfs:comment "Sampling frequency in hertz."@en .
:sampleCount a owl:DatatypeProperty ; rdfs:domain :PhysiologicalRecord ; rdfs:range xsd:integer ; rdfs:label "sample count"@en ; rdfs:comment "Number of samples in a record."@en .
:channelName a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:string ; rdfs:label "channel name"@en ; rdfs:comment "Name of a signal channel."@en .
:channelUnit a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:string ; rdfs:label "channel unit"@en ; rdfs:comment "Unit string of a signal channel."@en .
:adcGain a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:decimal ; rdfs:label "ADC gain"@en ; rdfs:comment "Analog-to-digital conversion gain."@en .
:adcBaseline a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:integer ; rdfs:label "ADC baseline"@en ; rdfs:comment "Baseline value specified for a channel."@en .
:adcResolution a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:integer ; rdfs:label "ADC resolution"@en ; rdfs:comment "ADC resolution in bits."@en .
:initialValue a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:integer ; rdfs:label "initial value"@en ; rdfs:comment "Initial sample value from the header."@en .
:checksum a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:integer ; rdfs:label "checksum"@en ; rdfs:comment "Channel checksum."@en .
:wfdbFormat a owl:DatatypeProperty ; rdfs:domain :SignalChannel ; rdfs:range xsd:string ; rdfs:label "WFDB format"@en ; rdfs:comment "WFDB signal storage format."@en .
:fileName a owl:DatatypeProperty ; rdfs:domain :SourceDataFile ; rdfs:range xsd:string ; rdfs:label "file name"@en ; rdfs:comment "Name of a source data file."@en .
:filePath a owl:DatatypeProperty ; rdfs:domain :SourceDataFile ; rdfs:range xsd:string ; rdfs:label "file path"@en ; rdfs:comment "Path of a source data file."@en .
:fileExtension a owl:DatatypeProperty ; rdfs:domain :SourceDataFile ; rdfs:range xsd:string ; rdfs:label "file extension"@en ; rdfs:comment "Extension such as hea, dat, or atr."@en .
:annotationLabel a owl:DatatypeProperty ; rdfs:domain :StressAnnotation ; rdfs:range xsd:string ; rdfs:label "annotation label"@en ; rdfs:comment "Text label stored in an annotation."@en .
:biomarkerName a owl:DatatypeProperty ; rdfs:domain :BiomarkerAssay ; rdfs:range xsd:string ; rdfs:label "biomarker name"@en ; rdfs:comment "Name of a biomarker measured by an assay."@en .
:assayTime a owl:DatatypeProperty ; rdfs:domain :BiomarkerAssay ; rdfs:range xsd:dateTime ; rdfs:label "assay time"@en ; rdfs:comment "Time at which a biomarker assay was performed."@en .
:environmentDescription a owl:DatatypeProperty ; rdfs:domain :Environment ; rdfs:range xsd:string ; rdfs:label "environment description"@en ; rdfs:comment "Textual environmental information."@en .

#################################################################
# Controlled individuals
#################################################################

:subjectRole a owl:NamedIndividual, :SubjectRole ; rdfs:label "subject role"@en .
:observerRole a owl:NamedIndividual, :ObserverRole ; rdfs:label "observer role"@en .
:experimenterRole a owl:NamedIndividual, :ExperimenterRole ; rdfs:label "experimenter role"@en .
:relaxCondition a owl:NamedIndividual, :RelaxCondition, :BaselineCondition, :RecoveryCondition ; rdfs:label "relax condition"@en ; rdfs:comment "Condition corresponding to Relax annotations."@en .
:physicalStressCondition a owl:NamedIndividual, :PhysicalStressCondition ; rdfs:label "physical stress condition"@en .
:emotionalStressCondition a owl:NamedIndividual, :EmotionalStressCondition ; rdfs:label "emotional stress condition"@en .
:cognitiveStressCondition a owl:NamedIndividual, :CognitiveStressCondition ; rdfs:label "cognitive stress condition"@en .
:physicalLoadStressor a owl:NamedIndividual, :PhysicalStressor ; rdfs:label "physical load stressor"@en .
:emotionalStimulusStressor a owl:NamedIndividual, :EmotionalStressor ; rdfs:label "emotional stimulus stressor"@en .
:cognitiveTaskStressor a owl:NamedIndividual, :CognitiveStressor ; rdfs:label "cognitive task stressor"@en .
:heartRate a owl:NamedIndividual, :PhysiologicalProperty ; rdfs:label "heart rate"@en ; rdfs:comment "Heart rate measured in beats per minute."@en .
:electrodermalActivity a owl:NamedIndividual, :PhysiologicalProperty ; rdfs:label "electrodermal activity"@en ; rdfs:comment "EDA signal."@en .
:bloodOxygenSaturation a owl:NamedIndividual, :PhysiologicalProperty ; rdfs:label "SpO2"@en ; rdfs:comment "Peripheral blood oxygen saturation."@en .
:skinTemperature a owl:NamedIndividual, :PhysiologicalProperty ; rdfs:label "skin temperature"@en ; rdfs:comment "Skin or body temperature."@en .
:accelerationX a owl:NamedIndividual, :MovementProperty ; rdfs:label "acceleration x-axis"@en .
:accelerationY a owl:NamedIndividual, :MovementProperty ; rdfs:label "acceleration y-axis"@en .
:accelerationZ a owl:NamedIndividual, :MovementProperty ; rdfs:label "acceleration z-axis"@en .
:bodyMovement a owl:NamedIndividual, :BehavioralIndicator ; rdfs:label "body movement"@en .
:ambientTemperature a owl:NamedIndividual, :EnvironmentalProperty ; rdfs:label "ambient temperature"@en .
:ambientHumidity a owl:NamedIndividual, :EnvironmentalProperty ; rdfs:label "ambient humidity"@en .
:ambientNoise a owl:NamedIndividual, :EnvironmentalProperty ; rdfs:label "ambient noise"@en .

:wearableStressPlatform a owl:NamedIndividual, :WearableDevice ; rdfs:label "wearable stress measurement platform"@en ; rdfs:comment "Wearable platform hosting the example sensors."@en .
:accelerometerSensor a owl:NamedIndividual, :Accelerometer ; rdfs:label "accelerometer sensor"@en ; sosa:observes :accelerationX, :accelerationY, :accelerationZ ; :hostedOnPlatform :wearableStressPlatform .
:edaSensor a owl:NamedIndividual, :EDASensor ; rdfs:label "EDA sensor"@en ; sosa:observes :electrodermalActivity ; :hostedOnPlatform :wearableStressPlatform .
:temperatureSensor a owl:NamedIndividual, :TemperatureSensor ; rdfs:label "temperature sensor"@en ; sosa:observes :skinTemperature ; :hostedOnPlatform :wearableStressPlatform .
:spo2Sensor a owl:NamedIndividual, :SpO2Sensor ; rdfs:label "SpO2 sensor"@en ; sosa:observes :bloodOxygenSaturation ; :hostedOnPlatform :wearableStressPlatform .
:heartRateSensor a owl:NamedIndividual, :HeartRateSensor ; rdfs:label "heart rate sensor"@en ; sosa:observes :heartRate ; :hostedOnPlatform :wearableStressPlatform .

:wearableStressExperimentProcedure a owl:NamedIndividual, :StressExperiment ; rdfs:label "wearable stress experiment procedure"@en ; rdfs:comment "Procedure with repeated relax phases and physical, emotional, and cognitive stress phases."@en .
:humanExperimenter a owl:NamedIndividual, :Observer ; rdfs:label "human experimenter"@en ; :hasRole :experimenterRole .
:defaultLaboratoryEnvironment a owl:NamedIndividual, :Environment ; rdfs:label "default laboratory environment"@en ; :environmentDescription "Experimental environment for wearable stress measurement; detailed environmental values were not provided in the source files." .

